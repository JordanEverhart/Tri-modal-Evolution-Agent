# Optional local environment for the Train package. Do not put real secrets in Git.

CONDA_ROOT=/path/to/miniconda3
CONDA_ENV=qwen3omni
MS_SWIFT_ROOT=/path/to/ms-swift
VLLM_ROOT=/path/to/vllm_qwen3_omni
QWEN3OMNI_MODEL_PATH=/path/to/Qwen3-Omni-30B-A3B-Instruct

# Set this in your shell or scheduler secret store, not in a committed file.
XIAOMI_MIMO_API_KEY=
QWEN3OMNI_MIMO_CONFIG=configs/rewards/mimo_judge.example.yaml

# Use only if your compute node needs a proxy for the MIMO API.
PROXY_URL=http://admin:10808
