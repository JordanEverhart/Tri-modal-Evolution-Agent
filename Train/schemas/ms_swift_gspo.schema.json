{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ms-swift multimodal GSPO record",
  "description": "GSPO uses the same data shape as GRPO; the recipe switches importance_sampling_level to sequence.",
  "type": "object",
  "required": ["messages", "solution"],
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {"enum": ["system", "user", "assistant"]},
          "content": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "solution": {"type": "string"},
    "answer": {"type": "string"},
    "images": {"type": "array", "items": {"type": "string"}},
    "videos": {"type": "array", "items": {"type": "string"}},
    "audios": {"type": "array", "items": {"type": "string"}},
    "meta": {"type": "object"}
  },
  "additionalProperties": true
}
